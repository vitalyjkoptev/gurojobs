APP_NAME="GURO JOBS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://gurojobs.test
APP_TIMEZONE=Europe/Warsaw

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gurojobs
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@gurojobs.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Search (Meilisearch) ─────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# ── Jarvis AI ─────────────────────────────────────────
JARVIS_ENABLED=true
JARVIS_AI_ENABLED=true
JARVIS_API_KEY=           # Anthropic API key
JARVIS_MODEL=claude-sonnet-4-6

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=    # без @, например: gurojobs_auth_bot
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CHANNELS=        # comma-separated channel IDs
TELEGRAM_AUTH_REDIRECT=/dashboard
TELEGRAM_AUTH_TTL=86400   # окно валидности hash от Telegram, сек

# ── Stripe ────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Crypto (NOWPayments) ─────────────────────────────
CRYPTO_PROVIDER=nowpayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ── Sanctum ───────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=gurojobs.test,admin.gurojobs.com,localhost
